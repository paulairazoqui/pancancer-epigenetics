# ------------------------------------------------------------
# Data files
# ------------------------------------------------------------
# Raw source datasets are not version-controlled.
data/raw/**/*
!data/raw/**/
!data/raw/**/.gitkeep

# Interim derived artifacts are not version-controlled.
# Directory structure is preserved via .gitkeep files.
data/interim/**/*
!data/interim/**/
!data/interim/**/.gitkeep

# Processed analytical outputs are not version-controlled.
# Directory structure is preserved via .gitkeep files.
data/processed/**/*
!data/processed/**/
!data/processed/**/.gitkeep


# ------------------------------------------------------------
# Manuscript-ready results
# ------------------------------------------------------------
# Keep manuscript-ready results trackable by default.
# Add specific ignore rules here only for large temporary files.
results/**/.ipynb_checkpoints/
results/**/~*
results/**/*.tmp


# ------------------------------------------------------------
# Python / notebook cache
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.ipynb_checkpoints/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/


# ------------------------------------------------------------
# Environments
# ------------------------------------------------------------
.env
.venv/
venv/
env/


# ------------------------------------------------------------
# Build / distribution artifacts
# ------------------------------------------------------------
dist/
build/
*.egg-info/


# ------------------------------------------------------------
# OS / editor files
# ------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/